{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "contact": {
    "issues": "",
    "homepage": ""
  },
  "license": "${mod_license}",
  "environment": "*",
  "accessWidener": "${mod_id}.accesswidener",
  "entrypoints": {
    "main": [
      "net.justmili.serveradditions.ServerAdditions"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "${minecraft_version_constraint}"
  }
}